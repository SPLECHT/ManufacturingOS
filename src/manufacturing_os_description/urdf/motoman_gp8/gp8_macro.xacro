<?xml version="1.0" ?>
<robot name="motoman_gp8" xmlns:xacro="http://ros.org/wiki/xacro">

  <material name="yaskawa_blue">
    <color rgba="0.12941 0.14902 0.74902 1.0"/>
  </material>

  <xacro:macro name="motoman_gp8" params="prefix">

    <link name="world"/>
    <joint name="world_fixed" type="fixed">
      <parent link="world"/>
      <child link="${prefix}base_link"/>
    </joint>

    <link name="${prefix}base_link">
      <visual>
        <geometry>
          <mesh filename="package://manufacturing_os_description/meshes/visual/gp8_base_link.stl"/>
        </geometry>
        <material name="yaskawa_blue"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://manufacturing_os_description/meshes/collision/gp8_base_link.stl"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="1.0"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
      </inertial>
    </link>

    <link name="${prefix}link_1_s">
      <visual>
        <geometry>
          <mesh filename="package://manufacturing_os_description/meshes/visual/gp8_link_1_s.stl"/>
        </geometry>
        <material name="yaskawa_blue"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://manufacturing_os_description/meshes/collision/gp8_link_1_s.stl"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="1.0"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
      </inertial>
    </link>

    <link name="${prefix}link_2_l">
      <visual>
        <geometry>
          <mesh filename="package://manufacturing_os_description/meshes/visual/gp8_link_2_l.stl"/>
        </geometry>
        <material name="yaskawa_blue"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://manufacturing_os_description/meshes/collision/gp8_link_2_l.stl"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="1.0"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
      </inertial>
    </link>

    <link name="${prefix}link_3_u">
      <visual>
        <geometry>
          <mesh filename="package://manufacturing_os_description/meshes/visual/gp8_link_3_u.stl"/>
        </geometry>
        <material name="yaskawa_blue"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://manufacturing_os_description/meshes/collision/gp8_link_3_u.stl"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="1.0"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
      </inertial>
    </link>

    <link name="${prefix}link_4_r">
      <visual>
        <geometry>
          <mesh filename="package://manufacturing_os_description/meshes/visual/gp8_link_4_r.stl"/>
        </geometry>
        <material name="yaskawa_blue"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://manufacturing_os_description/meshes/collision/gp8_link_4_r.stl"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="1.0"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
      </inertial>
    </link>

    <link name="${prefix}link_5_b">
      <visual>
        <geometry>
          <mesh filename="package://manufacturing_os_description/meshes/visual/gp8_link_5_b.stl"/>
        </geometry>
        <material name="yaskawa_blue"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://manufacturing_os_description/meshes/collision/gp8_link_5_b.stl"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="1.0"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
      </inertial>
    </link>

    <link name="${prefix}link_6_t">
      <visual>
        <geometry>
          <mesh filename="package://manufacturing_os_description/meshes/visual/gp8_link_6_t.stl"/>
        </geometry>
        <material name="yaskawa_blue"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://manufacturing_os_description/meshes/collision/gp8_link_6_t.stl"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="1.0"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
      </inertial>
    </link>

    <joint name="${prefix}joint_1_s" type="revolute">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}link_1_s"/>
      <origin xyz="0 0 0.330" rpy="0 0 0" />
      <axis xyz="0 0 1" />
      <limit lower="${radians(-170)}" upper="${radians(170)}" effort="150.92" velocity="${radians(455)}"/>
    </joint>
    <joint name="${prefix}joint_2_l" type="revolute">
      <parent link="${prefix}link_1_s"/>
      <child link="${prefix}link_2_l"/>
      <origin xyz="0.040 0 0" rpy="0 0 0" />
      <axis xyz="0 1 0" />
      <limit lower="${radians(-65)}" upper="${radians(145)}" effort="176.4" velocity="${radians(385)}"/>
    </joint>
    <joint name="${prefix}joint_3_u" type="revolute">
      <parent link="${prefix}link_2_l"/>
      <child link="${prefix}link_3_u"/>
      <origin xyz="0 0 0.345" rpy="0 0 0" />
      <axis xyz="0 -1 0" />
      <limit lower="${radians(-70)}" upper="${radians(190)}" effort="107.56" velocity="${radians(520)}"/>
    </joint>
    <joint name="${prefix}joint_4_r" type="revolute">
      <parent link="${prefix}link_3_u"/>
      <child link="${prefix}link_4_r"/>
      <origin xyz="0.340 0 0.040" rpy="0 0 0" />
      <axis xyz="-1 0 0" />
      <limit lower="${radians(-190)}" upper="${radians(190)}" effort="55.86" velocity="${radians(550)}"/>
    </joint>
    <joint name="${prefix}joint_5_b" type="revolute">
      <parent link="${prefix}link_4_r"/>
      <child link="${prefix}link_5_b"/>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <axis xyz="0 -1 0" />
      <limit lower="${radians(-135)}" upper="${radians(135)}" effort="32.68" velocity="${radians(550)}"/>
    </joint>
    <joint name="${prefix}joint_6_t" type="revolute">
      <parent link="${prefix}link_5_b"/>
      <child link="${prefix}link_6_t"/>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <axis xyz="-1 0 0" />
      <limit lower="${radians(-360)}" upper="${radians(360)}" effort="22.54" velocity="${radians(1000)}"/>
    </joint>

    <link name="${prefix}flange"/>
    <joint name="${prefix}joint_6_t-flange" type="fixed">
      <origin xyz="0.080 0 0" rpy="0 0 0"/>
      <parent link="${prefix}link_6_t"/>
      <child link="${prefix}flange"/>
    </joint>

    <link name="${prefix}tool0"/>
    <joint name="${prefix}flange-tool0" type="fixed">
      <origin xyz="0 0 0" rpy="${radians(180)} ${radians(-90)} 0"/>
      <parent link="${prefix}flange"/>
      <child link="${prefix}tool0"/>
    </joint>

    <link name="${prefix}base" />
    <joint name="${prefix}base_link-base" type="fixed">
      <origin xyz="0 0 0.330" rpy="0 0 0"/>
      <parent link="${prefix}base_link"/>
      <child link="${prefix}base"/>
    </joint>

  </xacro:macro>

  <xacro:motoman_gp8 prefix=""/>

</robot>
