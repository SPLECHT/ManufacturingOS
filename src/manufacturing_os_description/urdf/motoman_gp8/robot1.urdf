    <joint name="joint_6_t">
      <command_interface name="position">
        <param name="min">-6.28</param>
        <param name="max">6.28</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
  </ros2_control>

  <gazebo>
    <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control_r1">
    <ros>
        <namespace>/robot1</namespace>
    </ros>
      <parameters>/home/mekatronik/ManufacturingOS/install/manufacturing_os_description/share/manufacturing_os_description/config/controllers.yaml</parameters>
