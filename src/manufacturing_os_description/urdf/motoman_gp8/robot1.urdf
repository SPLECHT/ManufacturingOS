<?xml version="1.0" ?>
<robot name="robot1">
  <material name="yaskawa_blue">
    <color rgba="0.12941 0.14902 0.74902 1.0"/>
  </material>
  
  <link name="world"/>
  <joint name="world_fixed" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
  </joint>
  
  <link name="base_link">
    <visual>
      <geometry>
        <mesh filename="package://manufacturing_os_description/meshes/visual/gp8_base_link.stl"/>
      </geometry>
      <material name="yaskawa_blue"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://manufacturing_os_description/meshes/collision/gp8_base_link.stl"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>
  
